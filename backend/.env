# Variables de entorno para el backend
# Para desarrollo local: configura estas variables.
# Para Railway: configura estas mismas variables en el dashboard de Railway (Variables de Entorno) para tu servicio de backend.

# Puerto del servidor (Railway lo asigna automáticamente, pero puedes definirlo si quieres)
PORT=3000

# URL de conexión a la base de datos MySQL
# En desarrollo local: usa tu configuración de XAMPP o similar.
# En Railway: copia la DATABASE_URL que Railway te proporciona al crear una base de datos MySQL.
DATABASE_URL=mysql://root:@localhost:3306/proyecto_cero
MYSQLHOST=ballast.proxy.rlwy.net
 MYSQLPORT=15170
 MYSQLUSER=root
  MYSQLPASSWORD=VUjNwZWqwQZWwmmxxFtWXqqwFjfMFuVl
 MYSQLDATABASE=railway